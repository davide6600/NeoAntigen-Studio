# Copia in .env e personalizza
NEOANTIGEN_APPROVAL_SECRET=change-me-in-production
NEOANTIGEN_REPORT_FORMAT=markdown   # markdown | pdf | html
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Opzionale: se NetMHCpan è installato nel container worker
NETMHCPAN_PATH=/opt/netMHCpan/netMHCpan
